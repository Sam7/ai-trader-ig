{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "macroSummary": { "type": "string" },
    "marketRegimeSummary": { "type": "string" },
    "marketRegime": {
      "type": "string",
      "enum": [ "Unknown", "RiskOn", "RiskOff", "Mixed", "EventDriven", "RangeBound", "TrendDayCandidate" ]
    },
    "rankedMarkets": {
      "type": "array",
      "minItems": {{WATCHLIST_SIZE}},
      "maxItems": {{WATCHLIST_SIZE}},
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "instrumentId": { "type": "string" },
          "instrumentName": { "type": "string" },
          "rank": { "type": "integer" },
          "rationale": { "type": "string" },
          "longScenario": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "thesis": { "type": "string" },
              "confirmation": { "type": "string" },
              "invalidation": { "type": "string" },
              "expectedCatalysts": {
                "type": "array",
                "items": { "type": "string" }
              },
              "avoidTradingUntilUtc": {
                "type": [ "string", "null" ],
                "format": "date-time"
              }
            },
            "required": [ "thesis", "confirmation", "invalidation", "expectedCatalysts", "avoidTradingUntilUtc" ]
          },
          "shortScenario": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "thesis": { "type": "string" },
              "confirmation": { "type": "string" },
              "invalidation": { "type": "string" },
              "expectedCatalysts": {
                "type": "array",
                "items": { "type": "string" }
              },
              "avoidTradingUntilUtc": {
                "type": [ "string", "null" ],
                "format": "date-time"
              }
            },
            "required": [ "thesis", "confirmation", "invalidation", "expectedCatalysts", "avoidTradingUntilUtc" ]
          }
        },
        "required": [
          "instrumentId",
          "instrumentName",
          "rank",
          "rationale",
          "longScenario",
          "shortScenario"
        ]
      }
    },
    "catalysts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "event": { "type": "string" },
          "status": { "type": "string" },
          "affectedMarkets": { "type": "array", "items": { "type": "string" } },
          "directionalPressure": { "type": "string" },
          "likelyTimeHorizon": { "type": "string" },
          "marketPricingView": { "type": "string" },
          "confirmationSignals": { "type": "string" },
          "weakeningSignals": { "type": "string" },
          "followUpCandidate": { "type": "boolean" }
        },
        "required": [
          "id",
          "event",
          "status",
          "affectedMarkets",
          "directionalPressure",
          "likelyTimeHorizon",
          "marketPricingView",
          "confirmationSignals",
          "weakeningSignals",
          "followUpCandidate"
        ]
      }
    },
    "opportunities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "marketArea": { "type": "string" },
          "currentBias": { "type": "string" },
          "whyItIsInterestingNow": { "type": "string" },
          "whatNeedsDeeperResearch": { "type": "string" },
          "whatStrengthensConviction": { "type": "string" },
          "whatReducesConviction": { "type": "string" },
          "primaryDependency": { "type": "string" },
          "timeHorizon": { "type": "string" },
          "priority": { "type": "string" }
        },
        "required": [
          "id",
          "marketArea",
          "currentBias",
          "whyItIsInterestingNow",
          "whatNeedsDeeperResearch",
          "whatStrengthensConviction",
          "whatReducesConviction",
          "primaryDependency",
          "timeHorizon",
          "priority"
        ]
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "risk": { "type": "string" },
          "whyItMattersNow": { "type": "string" },
          "whatItCouldBreak": { "type": "string" },
          "earlyWarningSign": { "type": "string" },
          "resolutionSignal": { "type": "string" }
        },
        "required": [
          "id",
          "risk",
          "whyItMattersNow",
          "whatItCouldBreak",
          "earlyWarningSign",
          "resolutionSignal"
        ]
      }
    },
    "calendarEvents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "scheduledAtUtc": { "type": "string", "format": "date-time" },
          "impact": {
            "type": "string",
            "enum": [ "Low", "Medium", "High" ]
          },
          "affectedInstrumentIds": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": [ "id", "title", "scheduledAtUtc", "impact", "affectedInstrumentIds" ]
      }
    }
  },
  "required": [ "macroSummary", "marketRegimeSummary", "marketRegime", "rankedMarkets", "catalysts", "opportunities", "risks", "calendarEvents" ]
}
